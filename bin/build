#!/usr/bin/env sh

BOLD='\033[1m'
RED='\033[31m'
RESET='\033[0m'

core_count() {
  echo "$(lscpu | grep Total | tr -s ' ' | cut -d':' -f 2)"
}

builder_count() {
  cores=$(core_count)
  builders=$(( cores / 4 ))
  if [ $builders -gt 0 ]; then
    echo "${builders}"
  else
    echo "1"
  fi
}

get_arch() {
  echo "$(uname -p)"
}

main() {
  local arch="$(get_arch)"
  local builders="$(builder_count)"

  ./bin/update
  echo

  printf "${BOLD}== Building 14.4-RELEASE…${RESET}\n" >&2
  poudriere bulk -J ${builders} -f packages-default -O beam -j "144${arch}"
  echo

  printf "${BOLD}== Building 15.1-RELEASE…${RESET}\n" >&2
  poudriere bulk -J ${builders} -f packages-default -O beam -j "151${arch}"
}

main
